rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isManager() {
      return signedIn() && userDoc().data.role == 'manager' && userDoc().data.active == true;
    }
    function isCashier() {
      return signedIn() && userDoc().data.role == 'cashier' && userDoc().data.active == true;
    }
    function isStaff() {
      return isManager() || isCashier();
    }

    /** Cashier may only bump order counter when checking out */
    function isOrderCounterUpdate() {
      return isCashier()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['nextOrderNumber', 'updatedAt']);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isManager());
      allow create: if isManager();
      allow update: if isManager() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isManager();
    }

    match /menu_categories/{id} {
      allow read: if isStaff();
      allow write: if isManager();
    }
    match /menu_items/{id} {
      allow read: if isStaff();
      allow write: if isManager();
    }
    match /recipes/{id} {
      allow read: if isStaff();
      allow write: if isManager();
    }
    match /ingredients/{id} {
      allow read: if isStaff();
      allow write: if isManager();
    }
    match /inventory_transactions/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if false;
    }
    match /cash_drawer_transactions/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if false;
    }
    match /shifts/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if false;
    }
    match /suppliers/{id} {
      allow read: if isStaff();
      allow write: if isManager();
    }
    match /supplier_transactions/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if false;
    }
    match /orders/{id} {
      allow read: if isStaff();
      allow create: if isCashier() || isManager();
      allow update: if isStaff();
    }
    match /order_items/{id} {
      allow read: if isStaff();
      allow create: if isCashier() || isManager();
    }
    match /payments/{id} {
      allow read: if isStaff();
      allow create: if isCashier() || isManager();
    }
    match /dining_tables/{id} {
      allow read: if isStaff();
      allow write: if isManager();
    }
    match /settings/{id} {
      allow read: if isStaff();
      allow create, delete: if isManager();
      allow update: if isManager() || isOrderCounterUpdate();
    }
  }
}
